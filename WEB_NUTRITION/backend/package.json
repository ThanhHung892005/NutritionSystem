{
  "name": "nutrition-system-backend",
  "version": "1.0.0",
  "description": "NutritionSystem API Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:create": "psql -U postgres -c \"CREATE DATABASE nutrition_system;\"",
    "db:init": "psql -U postgres -d nutrition_system -f src/db/schema.sql",
    "db:migrate": "psql -U postgres -d nutrition_system -f src/db/migration_phase2.sql && psql -U postgres -d nutrition_system -f src/db/migration_chat_history.sql && psql -U postgres -d nutrition_system -f src/db/migration_foods.sql",
    "db:seed": "psql -U postgres -d nutrition_system -f src/db/seed.sql",
    "db:setup": "npm run db:create && npm run db:init && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
