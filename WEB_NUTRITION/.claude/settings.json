{
  "permissions": {
    "allow": ["Bash(gh auth status)", "Bash(git init)", "Bash(git add -A)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cp \"$CLAUDE_TOOL_INPUT_FILE\" \"$CLAUDE_TOOL_INPUT_FILE.bak\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_TOOL_OUTPUT_FILE\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
